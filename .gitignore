# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
**/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# TextMeshPro (auto-imported by Unity)
**/[Aa]ssets/TextMesh Pro/
**/[Aa]ssets/TextMesh Pro.meta

# MobileDependencyResolver (auto-imported)
**/[Aa]ssets/MobileDependencyResolver/
**/[Aa]ssets/MobileDependencyResolver.meta

# Coplay local package cache
**/Packages/Coplay/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.idea/
*.swp
*.swo
*~

# Test results
test-results/
test-artifacts/

# iOS build artifacts
*.ipa
*.dSYM.zip
*.dSYM

# Screenshots (generated, not tracked)
screenshots/

# Large reference videos (keep frames only)
docs/references/*.mp4
docs/references/*.mkv
docs/references/*.webm
