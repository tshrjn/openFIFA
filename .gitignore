**/[Tt]emp/
**/[Oo]bj/
**/[Bb]uild/
**/[Bb]uilds/
**/[Ll]ogs/
**/[Uu]ser[Ss]ettings/

# MemoryCaptures can get large
**/[Mm]emoryCaptures/

# Recordings can get large
**/[Rr]ecordings/

# Uncomment if you don't want to track asset meta files
# *.meta

# Visual Studio cache directory
.vs/
**/.vscode/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Rider solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
